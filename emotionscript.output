Grammar

    0 $accept: program $end

    1 program: PROGRAM_MIND IDENTIFIER PROGRAM_AWAKE program_body PROGRAM_SLEEP

    2 program_body: /* empty */
    3             | statement_list

    4 statement_list: statement
    5               | statement_list statement

    6 statement: declaration_stmt
    7          | assignment_stmt
    8          | expression_stmt
    9          | function_declaration
   10          | conditional_stmt
   11          | loop_stmt
   12          | io_stmt
   13          | control_flow_stmt
   14          | persona_declaration
   15          | fsm_declaration
   16          | emotion_based_stmt
   17          | PROGRAM_ABORT DELIM_SEMICOLON
   18          | PROGRAM_SCENE IDENTIFIER DELIM_SEMICOLON
   19          | error DELIM_SEMICOLON

   20 declaration_stmt: type_specifier IDENTIFIER DELIM_SEMICOLON
   21                 | variable_modifier type_specifier IDENTIFIER DELIM_SEMICOLON
   22                 | type_specifier IDENTIFIER OP_ARROW expression DELIM_SEMICOLON

   23 type_specifier: TYPE_COUNT
   24               | TYPE_MEASURE
   25               | TYPE_TRUTH
   26               | TYPE_WORDS
   27               | TYPE_LEVEL

   28 variable_modifier: VAR_THOUGHT
   29                  | VAR_MEMORY
   30                  | VAR_TRAIT
   31                  | VAR_STATE

   32 assignment_stmt: ASSIGN_SET IDENTIFIER OP_ARROW expression DELIM_SEMICOLON
   33                | ASSIGN_SET IDENTIFIER DELIM_DOT IDENTIFIER OP_ARROW expression DELIM_SEMICOLON

   34 expression_stmt: expression DELIM_SEMICOLON

   35 expression: primary_expression
   36           | expression OP_POWER expression
   37           | expression OP_MUL expression
   38           | expression OP_DIV expression
   39           | expression OP_MOD expression
   40           | expression OP_PLUS expression
   41           | expression OP_MINUS expression
   42           | expression OP_EQ expression
   43           | expression OP_NEQ expression
   44           | expression OP_LT expression
   45           | expression OP_GT expression
   46           | expression OP_LEQ expression
   47           | expression OP_GEQ expression
   48           | OP_INC IDENTIFIER
   49           | OP_DEC IDENTIFIER

   50 primary_expression: IDENTIFIER
   51                   | IDENTIFIER OP_INC
   52                   | IDENTIFIER OP_DEC
   53                   | IDENTIFIER DELIM_DOT IDENTIFIER
   54                   | IDENTIFIER DELIM_LPAREN argument_list DELIM_RPAREN
   55                   | IDENTIFIER DELIM_LPAREN DELIM_RPAREN
   56                   | FUNC_CALL IDENTIFIER DELIM_LPAREN argument_list DELIM_RPAREN
   57                   | FUNC_CALL IDENTIFIER DELIM_LPAREN DELIM_RPAREN
   58                   | LIT_INT
   59                   | LIT_FLOAT
   60                   | LIT_STRING
   61                   | LIT_BOOL
   62                   | DELIM_LPAREN expression DELIM_RPAREN
   63                   | math_function
   64                   | FSM_CURRENT

   65 function_declaration: FUNC_DECLARE IDENTIFIER DELIM_LPAREN parameter_list DELIM_RPAREN FUNC_RETURNS type_specifier DELIM_LSHIFT function_body DELIM_RSHIFT
   66                     | FUNC_DECLARE IDENTIFIER DELIM_LPAREN DELIM_RPAREN FUNC_RETURNS type_specifier DELIM_LSHIFT function_body DELIM_RSHIFT

   67 parameter_list: parameter
   68               | parameter_list DELIM_COMMA parameter

   69 parameter: type_specifier IDENTIFIER

   70 function_body: statement_list
   71              | statement_list FUNC_RETURN expression DELIM_SEMICOLON
   72              | FUNC_RETURN expression DELIM_SEMICOLON

   73 argument_list: expression
   74              | argument_list DELIM_COMMA expression

   75 math_function: MATH_SIN DELIM_LPAREN expression DELIM_RPAREN
   76              | MATH_COS DELIM_LPAREN expression DELIM_RPAREN
   77              | MATH_TAN DELIM_LPAREN expression DELIM_RPAREN
   78              | MATH_ASIN DELIM_LPAREN expression DELIM_RPAREN
   79              | MATH_ACOS DELIM_LPAREN expression DELIM_RPAREN
   80              | MATH_ATAN DELIM_LPAREN expression DELIM_RPAREN
   81              | MATH_ABS DELIM_LPAREN expression DELIM_RPAREN
   82              | MATH_SQRT DELIM_LPAREN expression DELIM_RPAREN
   83              | MATH_CEIL DELIM_LPAREN expression DELIM_RPAREN
   84              | MATH_FLOOR DELIM_LPAREN expression DELIM_RPAREN
   85              | MATH_NORM DELIM_LPAREN expression DELIM_RPAREN
   86              | MATH_POW DELIM_LPAREN expression DELIM_COMMA expression DELIM_RPAREN
   87              | MATH_DIFF DELIM_LPAREN expression DELIM_COMMA expression DELIM_RPAREN

   88 conditional_stmt: COND_IF condition statement_list COND_END
   89                 | COND_IF condition statement_list else_if_chain COND_END
   90                 | COND_IF condition statement_list COND_ELSE statement_list COND_END
   91                 | COND_IF condition statement_list else_if_chain COND_ELSE statement_list COND_END
   92                 | switch_stmt
   93                 | new_switch_stmt

   94 condition: expression

   95 else_if_chain: COND_ELSE_IF condition statement_list
   96              | else_if_chain COND_ELSE_IF condition statement_list

   97 switch_stmt: DECIDE_KW DELIM_LPAREN expression DELIM_RPAREN DELIM_LBRACE switch_body DELIM_RBRACE

   98 switch_body: switch_body_item
   99            | switch_body switch_body_item

  100 switch_body_item: expression DELIM_COLON
  101                 | OTHERWISE_KW DELIM_COLON
  102                 | statement

  103 new_switch_stmt: DECIDE_KW expression new_case_blocks END_DECISION_KW DELIM_DOT

  104 new_case_blocks: new_case_block
  105                | new_case_blocks new_case_block
  106                | new_case_blocks new_default_block

  107 new_case_block: WHEN_KW expression statement_list

  108 new_default_block: OTHERWISE_KW statement_list

  109 loop_stmt: LOOP_WHILE condition statement_list LOOP_END
  110          | LOOP_FOR DELIM_LPAREN assignment_stmt expression DELIM_SEMICOLON expression DELIM_RPAREN statement_list LOOP_END
  111          | new_while_stmt

  112 new_while_stmt: WHILE_FEELING_KW DELIM_LPAREN condition DELIM_RPAREN statement_list CALM_KW

  113 control_flow_stmt: LOOP_BREAK DELIM_SEMICOLON
  114                  | LOOP_CONTINUE DELIM_SEMICOLON

  115 io_stmt: IO_SPEAK DELIM_LPAREN expression DELIM_RPAREN DELIM_SEMICOLON
  116        | IO_LISTEN DELIM_LPAREN IDENTIFIER DELIM_RPAREN DELIM_SEMICOLON
  117        | IO_ALERT DELIM_LPAREN expression DELIM_RPAREN DELIM_SEMICOLON

  118 persona_declaration: CLASS_PERSONA IDENTIFIER DELIM_LSHIFT persona_body DELIM_RSHIFT
  119                    | CLASS_PERSONA IDENTIFIER CLASS_INHERIT IDENTIFIER DELIM_LSHIFT persona_body DELIM_RSHIFT

  120 persona_body: /* empty */
  121             | persona_member_list

  122 persona_member_list: persona_member
  123                    | persona_member_list persona_member

  124 persona_member: access_modifier variable_modifier type_specifier IDENTIFIER DELIM_SEMICOLON
  125               | access_modifier type_specifier IDENTIFIER DELIM_SEMICOLON
  126               | variable_modifier type_specifier IDENTIFIER DELIM_SEMICOLON
  127               | type_specifier IDENTIFIER DELIM_SEMICOLON
  128               | access_modifier function_declaration
  129               | function_declaration
  130               | CLASS_OVERRIDE function_declaration
  131               | CLASS_STATIC type_specifier IDENTIFIER DELIM_SEMICOLON

  132 access_modifier: CLASS_OPEN
  133                | CLASS_GUARDED
  134                | CLASS_HIDDEN

  135 fsm_declaration: FSM_TRANSITION IDENTIFIER WHEN_KW condition DELIM_SEMICOLON
  136                | FSM_EVENT IDENTIFIER DELIM_LPAREN DELIM_RPAREN DELIM_LBRACE statement_list DELIM_RBRACE
  137                | FSM_EVENT IDENTIFIER DELIM_LPAREN DELIM_RPAREN DELIM_LSHIFT statement_list DELIM_RSHIFT

  138 emotion_based_stmt: TYPE_EMOTION IDENTIFIER DELIM_SEMICOLON
  139                   | TYPE_EMOTION IDENTIFIER OP_ARROW expression DELIM_SEMICOLON
  140                   | TYPE_EMOTION IDENTIFIER FSM_STATES DELIM_LBRACE state_list DELIM_RBRACE DELIM_SEMICOLON

  141 state_list: IDENTIFIER
  142           | state_list DELIM_COMMA IDENTIFIER


